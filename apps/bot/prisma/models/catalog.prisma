model Plan {
    id   String @id @default(cuid())
    name String
    slug Slug? @unique

    maxUsers    Int?
    priceCents  Int?
    
    mercadoPagoPlanId String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    subscriptions Subscription[]

    @@map("plans")
}

enum Slug {
    free
    andromeda
}