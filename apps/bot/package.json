{
    "name": "pontobot",
    "version": "1.0.1",
    "type": "module",
    "main": "build/index.js",
    "private": true,
    "scripts": {
        "check": "tsc --noEmit && echo ✔ Ok",
        "build": "tsup",
        "dev": "tsx --env-file=.env ./src/index.ts",
        "watch": "tsx --watch --env-file=.env ./src/index.ts",
        "start": "prisma migrate deploy && node .",
        "prestart": ""
    },
    "dependencies": {
        "@constatic/base": "latest",
        "@fastify/cors": "10.0.1",
        "@fastify/jwt": "^10.1.0",
        "@fastify/oauth2": "^8.2.0",
        "@magicyan/discord": "1.7.3",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "chalk": "5.6.2",
        "discord.js": "^14.27.0",
        "dotenv": "^17.4.2",
        "fastify": "5.0.0",
        "http-status-codes": "2.3.0",
        "pg": "^8.22.0",
        "sharp": "^0.35.3"
    },
    "devDependencies": {
        "@types/node": "^22.20.1",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "tsup": "^8.3.5",
        "tsx": "4.19.3",
        "typescript": "5.9.3"
    },
    "imports": {
        "#base": [
            "./build/discord/index.js"
        ],
        "#functions": [
            "./build/functions/index.js"
        ],
        "#database": [
            "./build/database/index.js"
        ],
        "#server": [
            "./build/server/index.js"
        ],
        "#menus": [
            "./build/menus/index.js"
        ],
        "#tools": [
            "./build/tools/index.js"
        ],
        "#lib/*": [
            "./build/lib/*"
        ],
        "#shared/*": [
            "./build/shared/*"
        ],
        "#enums": [
            "./build/database/prisma/enums.js"
        ]
    },
    "baseVersion": "1.5.9"
}
